# Environment Variables Example
# Copy this file to .env and fill in your keys

# LLM Providers
OPENAI_API_KEY=your_openai_api_key_here
#
# AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
# AZURE_OPENAI_ENDPOINT=your_azure_endpoint_here
#
# PinchBench evaluation (evals/tasks/pinchbench.py): runs pinchbench tasks
# against the Taskforce agent through Inspect AI. Both the agent under
# test AND the LLM judge call into the Taskforce LLM provider (LiteLLM)
# using whatever model alias is configured in
# src/taskforce/configs/llm_config.yaml. By default this means Azure
# OpenAI — set AZURE_API_KEY / AZURE_API_BASE / AZURE_API_VERSION above.
# No OpenClaw or upstream pinchbench-runner dependency.

# Infrastructure
# Production: PostgreSQL via asyncpg.
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/taskforce
# Dev (zero-infra): SQLite via aiosqlite. Migrations fall back from JSONB to JSON.
# DATABASE_URL=sqlite+aiosqlite:///D:/absolute/path/to/.taskforce/enterprise.db

# Enterprise plugin (taskforce-enterprise)
# HS256 signing secret for JWTs issued by /api/v1/auth/login. Required —
# jwt_issuer.py raises RuntimeError → 500 on login if unset. Generate with
# `python -c "import secrets; print(secrets.token_urlsafe(48))"`.
# TASKFORCE_JWT_SECRET=replace_me_with_a_long_random_secret
#
# Path to the framework's plugin-config YAML. The framework reads this file
# and passes `config["enterprise"]` to `EnterprisePlugin.initialize()`.
# Without it, auth.provider defaults to "stub" which rejects every Bearer
# token (every authenticated request 401s after login). See the wrapper at
# `.taskforce/plugin-config.yaml` for the expected `enterprise:` structure.
# TASKFORCE_PLUGIN_CONFIG=D:/home/Source/pytaskforce/.taskforce/plugin-config.yaml
#
# Bootstrap admin tenant created idempotently by
# `taskforce-enterprise admin bootstrap` (also runs via `.\dev.ps1 -Migrate`).
# TASKFORCE_BOOTSTRAP_TENANT=browser_tenant
# TASKFORCE_BOOTSTRAP_TENANT_NAME=Browser Tenant
# TASKFORCE_BOOTSTRAP_ADMIN_EMAIL=admin.browser@example.com
# TASKFORCE_BOOTSTRAP_ADMIN_PASSWORD=ChangeMe1234!

# Windows / PowerShell: force UTF-8 stdout so the bootstrap CLI's ✓ / •
# glyphs don't crash cp1252 consoles.
# PYTHONIOENCODING=utf-8

# Tools
# GITHUB_TOKEN=your_github_token_here
# BING_SEARCH_API_KEY=your_bing_key_here

# Communication Providers
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
