{
  "eval_id": 2,
  "eval_name": "foreign-reverse-charge",
  "prompt": "Rechnung von Fortuna S.R.L., Via Roma 123, 20100 Milano, IT12345678901. Nr. 2024-4567, Datum 03.02.2026. Software Lizenz Annual 1200 EUR netto, Consulting Services 800 EUR netto. Reverse Charge gemaess §13b UStG. Gesamtbetrag 2000 EUR netto.",
