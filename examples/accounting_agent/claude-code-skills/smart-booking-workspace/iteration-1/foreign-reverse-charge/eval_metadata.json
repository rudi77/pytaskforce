    },
    {
      "name": "consulting_account_4950",
      "description": "Consulting auf Konto 4950 (Beratungskosten)",
      "check": "output contains '4950'"
    },
    {
      "name": "reverse_charge_vat_1577",
      "description": "Vorsteuer auf 1577 (Reverse Charge) statt 1576",
      "check": "output contains '1577'"
    },
    {
      "name": "reverse_charge_recognized",
      "description": "Reverse Charge / §13b UStG erkannt und erwaehnt",
