# BluBot per-customer environment file
# Generated by provision_customer.py — values substituted at provision time.
# Customer: {{CUSTOMER_NAME}}

# ── Customer identity ────────────────────────────────────────────────
AP_LEDGER_CUSTOMER_NAME={{CUSTOMER_NAME}}
AP_LEDGER_COUNTRY={{COUNTRY}}

# ── Per-customer roots (used by deploy scripts to find db, belege, reports)
AP_LEDGER_ROOT={{CUSTOMER_DIR}}
AP_LEDGER_DB_PATH={{CUSTOMER_DIR}}/db/ap-ledger.db
AP_LEDGER_BELEGE_DIR={{CUSTOMER_DIR}}/belege
TASKFORCE_WORK_DIR={{CUSTOMER_DIR}}/.taskforce_ap_ledger

# ── Telegram (one bot per customer) ──────────────────────────────────
TELEGRAM_BOT_TOKEN={{TELEGRAM_BOT_TOKEN}}

# ── LLM credentials (shared across customers — copy from your main .env)
# Uncomment and set for your provider:
# AZURE_API_KEY=
# AZURE_API_BASE=
# AZURE_API_VERSION=2024-12-01-preview
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
