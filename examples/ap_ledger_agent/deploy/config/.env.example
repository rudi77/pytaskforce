# =============================================================================
# AP-Ledger Agent — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# The .env file is loaded automatically by Taskforce.

# ── Root Directory ──────────────────────────────────────────────────────────
# Base directory for all AP-Ledger data (DB, belege, session state).
# Default: relative to skill scripts directory (two levels up).
# RECOMMENDED: Set this explicitly for production use.
AP_LEDGER_ROOT=C:\Users\anna\ap-ledger-agent

# ── Country ─────────────────────────────────────────────────────────────────
# Controls tax codes, seed data, and compliance rules.
# Options: AT (Austria), DE (Germany)
AP_LEDGER_COUNTRY=AT

# ── Database ────────────────────────────────────────────────────────────────
# Override the default database path (default: ${AP_LEDGER_ROOT}/db/ap-ledger.db)
# AP_LEDGER_DB_PATH=C:\Users\anna\ap-ledger-agent\db\ap-ledger.db

# ── Belege Archive ──────────────────────────────────────────────────────────
# Override the receipt archive directory (default: ${AP_LEDGER_ROOT}/belege)
# AP_LEDGER_BELEGE_DIR=C:\Users\anna\ap-ledger-agent\belege

# ── LLM Provider ───────────────────────────────────────────────────────────
# Uncomment ONE provider block below.

# Azure OpenAI (default — vision-capable for receipt photos):
AZURE_API_KEY=your-azure-api-key-here
AZURE_API_BASE=https://your-resource.openai.azure.com/
AZURE_API_VERSION=2024-02-15-preview

# OpenAI direct:
# OPENAI_API_KEY=sk-...

# Anthropic Claude:
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini:
# GEMINI_API_KEY=...

# Ollama (local — no key needed, just run `ollama serve`):
# No environment variable needed

# ── Telegram ───────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Your Telegram chat ID (send /start to your bot, then check the chat ID)
TELEGRAM_RECIPIENT_ID=your-chat-id-here

# ── Optional ───────────────────────────────────────────────────────────────
# GitHub token (for GitHub tool, if enabled)
# GITHUB_TOKEN=ghp_...
