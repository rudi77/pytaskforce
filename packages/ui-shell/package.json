{
  "name": "@taskforce/ui-shell",
  "version": "0.1.0",
  "description": "Shared design system, API client and plugin contract for the Taskforce management UI and its plugins.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "pnpm": ">=11.0.0"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tailwind.preset": {
      "types": "./tailwind.preset.d.ts",
      "default": "./tailwind.preset.cjs"
    }
  },
  "files": [
    "dist",
    "tailwind.preset.cjs",
    "tailwind.preset.d.ts",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.59.0",
    "lucide-react": "^0.453.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "tailwindcss": "^3.4.13",
    "zustand": "^5.0.0"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.59.0",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "lucide-react": "^0.453.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3",
    "vite": "^5.4.9",
    "vite-plugin-dts": "^4.3.0",
    "zustand": "^5.0.0"
  }
}
