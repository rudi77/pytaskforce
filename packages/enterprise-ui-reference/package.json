    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@taskforce/ui-shell": "file:../ui-shell",
    "@tanstack/react-query": "^5.59.0",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "lucide-react": "^0.453.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.9",
    "vite-plugin-dts": "^4.3.0"
  }
