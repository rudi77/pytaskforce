  "scripts": {
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit"
  },
  "peerDependencies": {
    "@taskforce/ui-shell": "^0.1.0",
    "@tanstack/react-query": "^5.59.0",
    "lucide-react": "^0.453.0",
